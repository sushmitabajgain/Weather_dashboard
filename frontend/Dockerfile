FROM node:20-alpine AS build

WORKDIR /app

ARG VITE_API_URL
ARG VITE_BASE_URL
ARG VITE_AGENT_URL
ARG VITE_MAP_STYLE_URL
ARG VITE_DASHBOARD_ALL_DATA_YEAR
ARG VITE_DEFAULT_TIME_RANGE
ARG VITE_DEFAULT_DATASET_TYPE

ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_BASE_URL=${VITE_BASE_URL}
ENV VITE_AGENT_URL=${VITE_AGENT_URL}
ENV VITE_MAP_STYLE_URL=${VITE_MAP_STYLE_URL}
ENV VITE_DASHBOARD_ALL_DATA_YEAR=${VITE_DASHBOARD_ALL_DATA_YEAR}
ENV VITE_DEFAULT_TIME_RANGE=${VITE_DEFAULT_TIME_RANGE}
ENV VITE_DEFAULT_DATASET_TYPE=${VITE_DEFAULT_DATASET_TYPE}

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf.template /etc/nginx/templates/default.conf.template
